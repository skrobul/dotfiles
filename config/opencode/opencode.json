{
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_PAT}"
      },
      "enabled": false
    },
    "todoist": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@greirson/mcp-todoist"
      ],
      "enabled": false
    }
  },
  "permission": {
    "bash": "ask",
    "edit": "ask"
  },
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "glm47flash-pvc": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "PVC instance of GLM4.7 flash",
      "models": {
        "glm-4.7-flash": {}
      },
      "options": {
        "baseURL": "https://llm.rpcai.rackspace-cloud.com/v1",
        "apiKey": "{env:GLM_PVC_API_KEY}"
      }
    },
    "flair": {
      "npm": "@ai-sdk/anthropic",
      "name": "Rackspace Flair QA",
      "options": {
        "baseURL": "https://flair-qa.rackspace.net/v1",
        "apiKey": "{env:FLAIR_SONNET46}",
      },
      "models": {
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6"
        },
        "nova-micro": {
          "name": "Nova micro",
          "limit": {
            "context": 0,
            "output": 10000
          }
        },
      }
    },
    "ollama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "models": {
        "gemma3:12b": {},
        "phi4:14b": {},
        "qwen3-coder": {}
      },
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    },
    "kiro": {
      "models": {
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "claude-sonnet-4-5-thinking": {
          "name": "Claude Sonnet 4.5 Thinking",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "medium": {
              "thinkingConfig": {
                "thinkingBudget": 16384
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
